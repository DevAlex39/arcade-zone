# ─── Server ───────────────────────────────────────────────────────
PORT=3000
CLIENT_URL=http://localhost:5173

# ─── JWT ──────────────────────────────────────────────────────────
JWT_SECRET=change_me_to_something_long_and_random_32chars_min

# ─── MySQL ────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=plateforme_jeux

# ─── Google OAuth (optionnel) ─────────────────────────────────────
# Créer un projet sur https://console.cloud.google.com
# Activer Google+ API, ajouter redirect URI: http://localhost:3000/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
